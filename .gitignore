# ============================================================
# Resume Analyzer — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Trained Model Files (too large for git) ---
# These are regenerated by running: python main.py
models/*.pkl

# --- Dataset (downloaded at runtime) ---
# Regenerated by running: python main.py
data/*.csv

# --- Jupyter Notebook Checkpoints ---
.ipynb_checkpoints/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS Files ---
Thumbs.db
.DS_Store
desktop.ini

# --- Virtual Environment ---
venv/
env/
.env/

# --- Distribution ---
*.whl
*.tar.gz
